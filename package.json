{
  "name": "ts-chas",
  "repository": "github:sinzek/chas",
  "homepage": "https://docs.cbrock.dev",
  "version": "1.1.6",
  "type": "module",
  "description": "A functional programming and utility library for TypeScript that provides tools for explicit error handling, runtime validation, and asynchronous operations.",
  "keywords": [
    "functional",
    "utility",
    "typescript",
    "error-handling",
    "validation",
    "async",
    "monads",
    "result",
    "option",
    "task",
    "guard",
    "schema",
    "tagged-errors",
    "pipe",
    "flow"
  ],
  "author": "Chase Brock",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sinzek/chas/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tagged-errs": {
      "import": {
        "types": "./dist/tagged-errs.d.ts",
        "default": "./dist/tagged-errs.js"
      },
      "require": {
        "types": "./dist/tagged-errs.d.cts",
        "default": "./dist/tagged-errs.cjs"
      }
    },
    "./result": {
      "import": {
        "types": "./dist/result/index.d.ts",
        "default": "./dist/result/index.js"
      },
      "require": {
        "types": "./dist/result/index.d.cts",
        "default": "./dist/result/index.cjs"
      }
    },
    "./option": {
      "import": {
        "types": "./dist/option.d.ts",
        "default": "./dist/option.js"
      },
      "require": {
        "types": "./dist/option.d.cts",
        "default": "./dist/option.cjs"
      }
    },
    "./task": {
      "import": {
        "types": "./dist/task.d.ts",
        "default": "./dist/task.js"
      },
      "require": {
        "types": "./dist/task.d.cts",
        "default": "./dist/task.cjs"
      }
    },
    "./guard": {
      "import": {
        "types": "./dist/guard/index.d.ts",
        "default": "./dist/guard/index.js"
      },
      "require": {
        "types": "./dist/guard/index.d.cts",
        "default": "./dist/guard/index.cjs"
      }
    },
    "./pipe": {
      "import": {
        "types": "./dist/pipe.d.ts",
        "default": "./dist/pipe.js"
      },
      "require": {
        "types": "./dist/pipe.d.cts",
        "default": "./dist/pipe.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && pnpm run build:dts",
    "build:dts": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist && pnpm run build:dts:cjs",
    "build:dts:cjs": "find dist -name \"*.d.ts\" -exec sh -c 'cp \"$1\" \"${1%.d.ts}.d.cts\"' _ {} \\;",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc --out docs --plugin typedoc-plugin-coverage",
    "docs:deploy": "pnpm run docs && gh-pages -d docs",
    "docs:deploy:ci": "pnpm run docs && gh-pages -d docs -r https://x-access-token:${GITHUB_TOKEN}@github.com/sinzek/chas.git",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "fast-check": "^4.6.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-coverage": "^4.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1"
  },
  "peerDependencies": {
    "fast-check": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "fast-check": {
      "optional": true
    }
  }
}
