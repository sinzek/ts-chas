{
  "name": "chas-ts",
  "version": "1.0.1",
  "type": "module",
  "description": "A functional programming and utility library for TypeScript that provides tools for explicit error handling, runtime validation, and asynchronous operations.",
  "keywords": [
    "functional",
    "utility",
    "typescript",
    "error-handling",
    "validation",
    "async",
    "monads",
    "result",
    "option",
    "task",
    "guard",
    "schema",
    "tagged-errors",
    "pipe",
    "flow"
  ],
  "author": "Chase Brock (github.com/sinzek)",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tagged-errs": {
      "types": "./dist/tagged-errs.d.ts",
      "import": "./dist/tagged-errs.js",
      "require": "./dist/tagged-errs.cjs"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "require": "./dist/result.cjs"
    },
    "./option": {
      "types": "./dist/option.d.ts",
      "import": "./dist/option.js",
      "require": "./dist/option.cjs"
    },
    "./task": {
      "types": "./dist/task.d.ts",
      "import": "./dist/task.js",
      "require": "./dist/task.cjs"
    },
    "./guard": {
      "types": "./dist/guard.d.ts",
      "import": "./dist/guard.js",
      "require": "./dist/guard.cjs"
    },
    "./pipe": {
      "types": "./dist/pipe.d.ts",
      "import": "./dist/pipe.js",
      "require": "./dist/pipe.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc --out docs",
    "docs:deploy": "pnpm run docs && gh-pages -d docs",
    "docs:deploy:ci": "pnpm run docs && gh-pages -d docs -r https://x-access-token:${GITHUB_TOKEN}@github.com/sinzek/chas.git"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
